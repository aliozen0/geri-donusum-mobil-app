rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== USERS COLLECTION =====
    match /users/{userId} {

      // READ: Herkes okuyabilir (leaderboard için)
      allow read: if true;

      // WRITE: Sadece kendi verini, doğrulanmış şekilde
      allow write: if isOwner(userId)
                   && isValidUserData()
                   && isRateLimited();

      // Kimlik doğrulama
      function isOwner(uid) {
        return request.auth != null && request.auth.uid == uid;
      }

      // Veri doğrulama - her alan kontrol ediliyor
      function isValidUserData() {
        let data = request.resource.data;
        return data.keys().hasAll(['name', 'avatar', 'totalPoints', 'totalScans', 'weekPoints'])
          // İsim: string, 1-20 karakter, boş değil
          && data.name is string
          && data.name.size() >= 1
          && data.name.size() <= 20
          // Avatar: string, max 10 karakter (emoji)
          && data.avatar is string
          && data.avatar.size() <= 10
          // Puanlar: sayı, pozitif, mantıklı üst limit
          && data.totalPoints is int
          && data.totalPoints >= 0
          && data.totalPoints <= 999999
          // Tarama: sayı, pozitif
          && data.totalScans is int
          && data.totalScans >= 0
          && data.totalScans <= 99999
          // Haftalık puan: sayı
          && data.weekPoints is int
          && data.weekPoints >= 0
          && data.weekPoints <= 99999
          // Streak: sayı
          && data.streak is int
          && data.streak >= 0
          && data.streak <= 9999
          // Puan artışı sınırı: tek seferde max 50 puan artabilir
          && (
            !exists(resource)  // yeni döküman oluşturma
            || data.totalPoints <= resource.data.totalPoints + 50
          )
          // Tarama artışı sınırı: tek seferde max 1 artabilir
          && (
            !exists(resource)
            || data.totalScans <= resource.data.totalScans + 1
          );
      }

      // Rate limiting: Son yazma zamanından 3 saniye geçmiş olmalı
      function isRateLimited() {
        return !exists(resource)
          || !('lastUpdate' in resource.data)
          || request.time > resource.data.lastUpdate + duration.value(3, 's');
      }
    }

    // Diğer tüm koleksiyonlara erişim engelle
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
